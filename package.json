{
  "name": "bharatmart-live",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm.cmd install --workspaces",
    "dev": "concurrently \"npm.cmd run dev --workspace frontend\" \"npm.cmd run dev --workspace backend\"",
    "build": "npm run build --workspace frontend",
    "start": "npm.cmd run start --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
